# Hope of Glory Ministry — Environment Template
# Copy to .env.local and fill in real values. Never commit real keys.

# ---- App ----
NEXT_PUBLIC_SITE_URL=https://hopeofglory.ministry
NEXT_PUBLIC_SITE_NAME=Hope of Glory Ministry
APP_ENV=development

# ---- Database ----
DATABASE_URL=postgresql://user:pass@host:5432/hope_of_glory
DATABASE_SSL=require

# ---- Redis ----
REDIS_URL=redis://default:pass@host:6379

# ---- Auth ----
AUTH_SECRET=change_me_to_a_64_char_random_string
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated list of admin Google emails. Only these can sign in to /admin.
ADMIN_EMAILS=
# Build version surfaced in /api/health and Sentry releases
APP_VERSION=0.1.0
NEXT_PUBLIC_SENTRY_DSN=

# ---- AI providers (workshop brain) ----
# Cerebras key pool — service-class isolation, NOT rate-limit evasion
CEREBRAS_KEY_SERMONS=
CEREBRAS_KEY_CHAT=
CEREBRAS_KEY_LIVE=
CEREBRAS_KEY_PHONE=
CEREBRAS_KEY_BACKGROUND=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# Premium verifier (deep theology, doctrine gate, crisis)
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-5

# Structured verification + embeddings
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_RESPONSES_STORE=false

# ---- Voice / Phone ----
SIGNALWIRE_PROJECT_ID=
SIGNALWIRE_TOKEN=
SIGNALWIRE_SPACE_URL=
SIGNALWIRE_PHONE_NUMBER=
DEEPGRAM_API_KEY=

# ---- Crisis escalation (US) ----
CRISIS_LIFELINE_988=988
CRISIS_EMERGENCY_911=911

# ---- Distribution ----
# Self-hosted Postiz (deployed alongside on Railway)
POSTIZ_URL=http://postiz:3000
POSTIZ_API_KEY=

# YouTube (direct API for Live)
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
# Refresh token from initial OAuth flow — required for headless broadcast creation
YOUTUBE_REFRESH_TOKEN=

# ---- Live stream scene defaults (Phase 7) ----
# Public URLs for the static backdrop + sermon audio used in the Phase 7 v1
# OBS-less pipeline. Replace with dynamic scene composition in Phase 7.5.
STREAM_FALLBACK_AUDIO=
STREAM_FALLBACK_IMAGE=

# ---- Email ----
RESEND_API_KEY=
EMAIL_FROM=hello@hopeofglory.ministry
EMAIL_FROM_NAME=Hope of Glory Ministry

# ---- Donations ----
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
# Hosted button IDs from PayPal Donate setup (shown on /give).
# /give renders Give Once + Give Monthly side-by-side and each needs its own id.
NEXT_PUBLIC_PAYPAL_HOSTED_BUTTON_ID_ONCE=
NEXT_PUBLIC_PAYPAL_HOSTED_BUTTON_ID_MONTHLY=
# Legacy alias kept for back-compat; new code prefers the _ONCE / _MONTHLY pair.
NEXT_PUBLIC_PAYPAL_HOSTED_BUTTON_ID=

# ---- Image / Video generation ----
FAL_API_KEY=
REPLICATE_API_TOKEN=
RUNWAY_API_KEY=

# ---- Monitoring ----
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ---- Storage ----
S3_BUCKET=
S3_REGION=
# Set for Cloudflare R2 or non-AWS S3-compatible providers. Leave blank for AWS S3.
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# ---- Security ----
PHONE_HASH_PEPPER=change_me_to_a_64_char_random_string
PHONE_HASH_PEPPER_PREV=
# Required to authorize the daily new-believer cron endpoint
CRON_SECRET=change_me_to_a_64_char_random_string

# ---- Feature flags (Phase rollout) ----
FEATURE_ASK_HOPE=true
FEATURE_PRAYER=true
FEATURE_DONATIONS=false
FEATURE_HOPE_LINE=false
FEATURE_LIVE_YOUTUBE=false
FEATURE_LIVE_DEBATE=false
FEATURE_X=false

# ---- Internationalization (Phase 12) ----
# When true, middleware-i18n will redirect users to their preferred locale.
# When false (default), all users land on the English version. Translated
# routes still work directly via /es/*, /pt/*, etc.
FEATURE_I18N=false

# ---- Crisis alerting ----
# Comma-separated list of emails to notify on imminent crisis events.
# Should include the founder + any on-call pastoral team member.
# Test end-to-end before go-live: POST /api/admin/alerts/test (admin only).
CRISIS_ALERT_EMAILS=

# ---- Backup ----
# S3 vars already set above are reused for backups. Backups land at
#   s3://${S3_BUCKET}/backups/postgres/YYYY-MM-DD/db-{timestamp}.dump
# Server-side AES256 encryption is forced on every upload (do not override).
# Retention is enforced by scripts/backup-cleanup.ts:
#   - last 7 days (daily)
#   - last 4 Sunday backups (weekly)
#   - last 12 first-of-month backups (monthly)
#   - every Jan-1 backup forever (yearly)
# Override the default daily window:
BACKUP_RETENTION_DAYS=7
